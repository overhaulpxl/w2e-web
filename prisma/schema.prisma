generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  package       String
  amount        Int
  status        String   @default("PENDING") // PENDING, SUCCESS, FAILED
  robloxUser    String?
  robloxPass    String?  // Diperlukan untuk metode 5 Days
  backupCode    String?  // Opsional
  whatsapp      String?
  paymentProof  String?  // Menyimpan path gambar screenshot QRIS
  buyType       String   @default("gamepass") // '5days' atau 'gamepass'
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

model Config {
  key   String @id
  value String
}

model Package {
  id      String @id @default(cuid())
  amount  Int
  price   Int
  type    String @default("Regular") // Regular, Best Value, Sultan
}

model SponsorshipPackage {
  id        String   @id @default(cuid())
  name      String
  price     String
  desc      String
  accent    String
  features  String   // Store as JSON string or newline separated
  cta       String
  popular   Boolean  @default(false)
  order     Int      @default(0)
}

model FrontPageContent {
  id      String @id @default(cuid())
  type    String // 'tiktok', 'gallery', 'team'
  value   String // URL gambar / ID video / User ID
  label   String? // Role tim atau alt text opsional
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Review {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  approved  Boolean  @default(false)
}

model DiscordStat {
  id          String   @id // Discord User ID
  displayName String?
  coins       Int      @default(0)
  xp          Int      @default(0)
  level       Int      @default(1)
  lastDaily   String?  // 'YYYY-MM-DD'
  updatedAt   DateTime @updatedAt
}
